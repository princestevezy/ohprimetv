ents/Navbar/Navbar\"\r\nimport Backgroundcolor from \"../../Components/Backgroundcolor/Backgroundcolor\"\r\nimport Footer from \"../../Components/Footer/Footer\";\r\nimport Carousel from 'react-bootstrap/Carousel';\r\nimport { homeimages } from '../../images/image';\r\n\r\n\r\nfunction Home() {\r\n  useEffect(() => {\r\n    Aos.init({ duration: 2000 });\r\n\r\n  }, []);\r\n  return (\r\n    <div>\r\n       <Navbar home={{color:\"gray\"}}>\r\n      </Navbar>\r\n        <Carousel>\r\n        <Carousel.Item>\r\n        <br/>\r\n        <br/>\r\n        <div className=\"d-block\" id=\"banner1\">\r\n        </div>\r\n        </Carousel.Item>\r\n        <Carousel.Item>\r\n          <br/>\r\n          <br/>\r\n        <div className=\"d-block\" id=\"banner2\">\r\n          </div>\r\n        </Carousel.Item>\r\n        <Carousel.Item>\r\n        <br/>\r\n        <br/>\r\n        <div className=\"d-block\" id=\"banner3\">\r\n        </div>\r\n      </Carousel.Item>\r\n      </Carousel>\r\n      <br></br>\r\n      <div class=\"center2\">\r\n      <div className=\"row a-row\">\r\n          <div className=\"col-md-6\">\r\n          <div data-aos=\"flip-left\" data-aos-duration=\"1000\">\r\n            <img className=\"img-1\" src={ homeimages[0]}/>\r\n          </div>\r\n        </div>\r\n          <div className=\"col-md-6\">\r\n          <div data-aos=\"flip-right\" data-aos-duration=\"1000\">\r\n            <h2 className=\"oh-prime-h1\"> Live Sport and TV-shows for family and best friends </h2>\r\n            <p className=\"oh-prime-p\">\r\n              Get access to all your favorite channels and share with family and friends ! With more than\r\n              40.000 streams between TV channels and VOD,\r\n              the world is open to you. Let’s join the Ohprime Family !\r\n              <br></br><br></br>\r\n             <Link to='/getstarted'><button className=\"btn btn\" style={{ fontSize: \"20px\", backgroundColor: \"red\", color: \"white\" }}> Get Started Now</button></Link>\r\n            </p>\r\n          </div>\r\n        </div>\r\n        </div>\r\n      </div><br></br>\r\n      <Backgroundcolor caroselcontent={\r\n        <div>\r\n          <br></br><br></br>\r\n          <div class=\"text-center center\">\r\n          <div className=\"row\">\r\n            <div class=\"col-md-4\">\r\n              <div data-aos=\"zoom-in\" data-aos-duration=\"2000\">\r\n                <img class=\"iconimage\" src={homeimages[1]}/>\r\n                <br></br>\r\n                <p className=\"white\">Download</p>\r\n              </div>\r\n            </div>\r\n            <div className=\"col-md-4\">\r\n              <div data-aos=\"zoom-in\" data-aos-duration=\"2000\">\r\n                <img className=\"iconimage\" src={homeimages[2]}/>\r\n                <br></br>\r\n                <p className=\"white\">Download</p>\r\n              </div>\r\n            </div>\r\n            <div className=\"col-md-4\">\r\n              <div data-aos=\"zoom-in\" data-aos-duration=\"2000\">\r\n                <img className=\"iconimage\" src={homeimages[3]}/>\r\n                <br></br>\r\n                <p className=\"white\">Download</p>\r\n              </div>\r\n            </div>\r\n            <div class=\"col-md-4\">\r\n              <div data-aos=\"zoom-in\" data-aos-duration=\"2000\">\r\n                <img className=\"iconimage\" src={homeimages[4]} />\r\n                <br></br>\r\n                <p className=\"white\">Download</p>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <br></br><br></br>\r\n        </div>\r\n        </div>\r\n      }>\r\n      </Backgroundcolor>\r\n      <br></br>\r\n      <h1 style={{ textAlign: \"center\"}} id='channels' class='tw'>Compatible with \r\n      <span className=\"span-h1\">all Devises</span>\r\n      </h1>\r\n      <br></br>\r\n      <div class=\"text-center center\">\r\n      <div className=\"row a-row\">\r\n        <div class=\"col-md-4\">\r\n          <div data-aos=\"zoom-in\" data-aos-duration=\"2000\">\r\n            <img class=\"iconimage2\" src={homeimages[5]} />\r\n          </div>\r\n        </div>\r\n        <div className=\"col-md-4\">\r\n          <div data-aos=\"zoom-in\" data-aos-duration=\"2000\">\r\n            <img className=\"iconimage2\" src={homeimages[6]} />\r\n          </div>\r\n        </div>\r\n        <div className=\"col-md-4\">\r\n          <div data-aos=\"zoom-in\" data-aos-duration=\"2000\">\r\n            <img className=\"iconimage2\" src={homeimages[7]} />\r\n          </div>\r\n        </div>\r\n        <div class=\"col-md-4\">\r\n          <div data-aos=\"zoom-in\" data-aos-duration=\"2000\">\r\n            <img className=\"iconimage2\" src={homeimages[8]} />\r\n          </div>\r\n        </div>\r\n        <div class=\"col-md-4\">\r\n          <div data-aos=\"zoom-in\" data-aos-duration=\"2000\">\r\n            <img className=\"iconimage2\" src={homeimages[9]}/>\r\n          </div>\r\n        </div>\r\n        <div class=\"col-md-4\">\r\n          <div data-aos=\"zoom-in\" data-aos-duration=\"2000\">\r\n            <img className=\"iconimage2\" src={homeimages[10]}/>\r\n          </div>\r\n      </div>\r\n      </div>\r\n      </div>\r\n      <div style={{ textAlign: \"center\"}}>\r\n        <br></br><br></br>\r\n      </div>\r\n      <Backgroundcolor caroselcontent={\r\n          <div>\r\n           <h1 className=\"white text-center\">\r\n            <font style={{ color: \"red\", fontSize: \"18px\" }}>Interesing</font>\r\n            <br></br>\r\n            Featured\r\n            <font style={{ color: \"red\", paddingLeft: \"10px\" }}>\r\n              Shows</font></h1>\r\n           <br></br>\r\n           <div className=\"not-mobileview\">\r\n          <div class=\"text-center center\">\r\n          <Carousel style={{ color: \"\", textAlign: \"center\" }}  buttomIcon={<span aria-hidden=\"true\" className=\"carousel-control-buttom-icon\" />}>\r\n          <Carousel.Item>\r\n           <div class=\"text-center\">\r\n           <div class=\"row a-row\">\r\n             <div class=\"col-3\">\r\n              <img class=\"gallary-img\" src={homeimages[11]}/>\r\n            </div>\r\n            <div class=\"col-3\">\r\n              <img class=\"gallary-img\" src={homeimages[12]}/>\r\n            </div>\r\n            <div class=\"col-3\">\r\n              <img class=\"gallary-img\" src={homeimages[13]} />\r\n            </div>\r\n            <div class=\"col-3\">\r\n            <img class=\"gallary-img\" src={homeimages[14]}/>\r\n            </div>\r\n            </div>\r\n            </div>\r\n            <br></br>\r\n          </Carousel.Item>\r\n          <Carousel.Item>\r\n           <div class=\"text-center\">\r\n           <div class=\"row a-row\">\r\n           <div class=\"col-3\">\r\n           <img class=\"gallary-img\" src={homeimages[15]}/>\r\n           </div>\r\n            <div class=\"col-3\">\r\n              <img class=\"gallary-img\" src={homeimages[16]}/>\r\n            </div>\r\n            <div class=\"col-3\">\r\n              <img class=\"gallary-img\" src={homeimages[17]}/>\r\n            </div>\r\n            <div class=\"col-3\">\r\n              <img class=\"gallary-img\" src={homeimages[18]}/>\r\n            </div>\r\n            </div>\r\n            </div>\r\n            <br></br>\r\n          </Carousel.Item>\r\n          </Carousel>\r\n          </div>\r\n          </div>\r\n          <div class=\"mobileview\">\r\n          <div class=\"text-center\">\r\n          <Carousel>\r\n          <Carousel.Item>  \r\n          <div class=\"row a-row\">\r\n          <div class=\"col-4\">\r\n           <img class=\"gallary-img\" src={homeimages[11]}/>\r\n           <p class='text-white'>Abejoye</p>\r\n          </div>\r\n            <div class=\"col-4\">\r\n            <img class=\"gallary-img\" src={homeimages[12]} />\r\n            <p class='text-white'>Heart Pain</p>\r\n            </div>\r\n            <div class=\"col-4\">\r\n            <img class=\"gallary-img\" src={homeimages[13]}/>\r\n            <p class='text-white'>The Cry Of An Angel</p>\r\n            </div>\r\n            </div> \r\n            </Carousel.Item>\r\n            <Carousel.Item>  \r\n          <div class=\"row a-row\">\r\n          <div class=\"col-4\">\r\n           <img class=\"gallary-img\" src={homeimages[15]}/>\r\n           <p class='text-white'>Legion</p>\r\n          </div>\r\n            <div class=\"col-4\">\r\n            <img class=\"gallary-img\" src={homeimages[16]} />\r\n            <p class='text-white'>Abejoye 5</p>\r\n            </div>\r\n            <div class=\"col-4\">\r\n            <img class=\"gallary-img\" src={homeimages[18]}/>\r\n            <p class='text-white'>Gbemi2</p>\r\n            </div>\r\n            </div> \r\n            </Carousel.Item>\r\n            </Carousel>\r\n            </div>\r\n            </div>\r\n          <br></br><br></br><br></br>\r\n          <br></br><br></br>\r\n          </div>\r\n      }>\r\n      </Backgroundcolor>\r\n      <br></br><br></br>\r\n      <div>\r\n        <h1 style={{ textAlign: \"Center\" }}>What our client says</h1>\r\n        <br></br>\r\n          <Carousel style={{ color: \"\", textAlign: \"center\" }} variant='dark' buttomIcon={<span aria-hidden=\"true\" className=\"carousel-control-buttom-icon\" />}>\r\n          <Carousel.Item>\r\n            <h5>John Emanuel</h5>\r\n            <i class='fa fa-star yellow'></i>\r\n            <i class='fa fa-star yellow'></i>\r\n            <i class='fa fa-star yellow'></i>\r\n            <p class='c-t'>I love the great service ohprime brings world wide.</p>\r\n            <br></br>\r\n          </Carousel.Item>\r\n          <Carousel.Item>\r\n            <h5>Rev Peter John</h5>\r\n            <i class='fa fa-star yellow'></i>\r\n            <i class='fa fa-star yellow'></i>\r\n            <i class='fa fa-star yellow'></i>\r\n            <p class='c-t'>I love the series Ohprime provides on there Tv channels.</p>\r\n            <br></br>\r\n          </Carousel.Item>\r\n          <Carousel.Item>\r\n            <h5>Esther Joy</h5>\r\n            <i class='fa fa-star yellow'></i>\r\n            <i class='fa fa-star yellow'></i>\r\n            <i class='fa fa-star yellow'></i>\r\n            <p class='c-t'>I love the sports ohprime provides on there tv channels .</p>\r\n            <br></br>\r\n          </Carousel.Item>\r\n        </Carousel>\r\n      </div>\r\n      <br></br><br></br>\r\n      <Footer />\r\n    </div>\r\n  );\r\n}\r\nexport default Home\r\n\r\n\r\n\r\n\r\n","C:\\Users\\Dozie Steven Emeka\\Documents\\Projects\\Javascript\\Webapp\\ohprimetv-main\\ohprimetv-main\\src\\Containers\\Aboutpage\\Aboutpage.jsx",[],[],"C:\\Users\\Dozie Steven Emeka\\Documents\\Projects\\Javascript\\Webapp\\ohprimetv-main\\ohprimetv-main\\src\\Containers\\Channelspage\\Channelspage.jsx",["97","98","99","100","101"],[],"import React from \"react\";\r\nimport '../../Containers/Homepage/Homepage.css';\r\nimport Table from 'react-bootstrap/Table';\r\nimport Navbar from \"../../Components/Navbar/Navbar\";\r\nimport Footer from \"../../Components/Footer/Footer\";\r\nimport { channelimages } from \"../../images/image\";\r\nimport Backgroundimage from \"../../Components/Backgroundimage/Backgroundimage\";\r\n\r\nfunction Channels() {\r\n  return (\r\n    <div>\r\n       <Navbar channels={{color:\"gray\"}}>\r\n       </Navbar>\r\n        <Backgroundimage pagetitle1='Channels' pagetitle2='Channels'>\r\n        </Backgroundimage>\r\n          <br/>\r\n          <br/>\r\n          <div class=\"text-center\">\r\n          <h1 class=\"text-center a-h1 tw\">Check Out  \r\n          <span className=\"span-h1\">Ohprime Channels</span></h1>\r\n          <br/>    \r\n          <Table striped bordered hover variant=\"\">\r\n      <thead>\r\n          <tr>\r\n          <th>No</th>\r\n          <th>Channel name</th>\r\n          <th>Channel image</th>\r\n          <th>About the channels</th>\r\n        </tr>\r\n      </thead>\r\n      <tbody>\r\n        <tr>\r\n          <td> 1</td>\r\n          <td><b>Dove Television</b></td>\r\n          <td><img class=\"iconimage2\" src={ channelimages[0] }/></td>\r\n          <td style={{width:\"40%\"}}><p style={{textAlign:\"justify\"}}>Dove Television, the official TV Channel of the\r\n           Redeemed Christian Church of God.</p></td>\r\n        </tr>\r\n        <tr>\r\n        <td>2</td>\r\n        <td><b>Dove Entertainment</b></td>\r\n        <td><img class=\"iconimage2\" src={ channelimages[1] }/></td>\r\n        <td style={{width:\"40%\"}}><p style={{textAlign:\"justify\"}}>Dove Television brings you Christian entertainment in its purest form; on \r\n         sports, movies, music, life style and more.</p></td>\r\n         </tr>\r\n         <tr>\r\n        <td>3</td>\r\n        <td><b>Dove Africa</b></td>\r\n        <td><img class=\"iconimage2\" src={ channelimages[0] }/></td>\r\n        <td style={{width:\"40%\"}}><p style={{textAlign:\"justify\"}}>\r\n        You want to know more about what God is doing \r\n        across the continent of Africa? Dove Africa gives you more; \r\n        from the mission fields, ministration and more \r\n        that will bless your hearts and souls.\r\n          </p></td> \r\n         </tr>\r\n         <tr>\r\n        <td>4</td>\r\n        <td><b>DOVE EUROPE</b></td>\r\n        <td><img class=\"iconimage2\" src={ channelimages[4] }/></td>\r\n        <td style={{width:\"40%\"}}><p style={{textAlign:\"justify\"}}>\r\n         Dove Europe is an extended arm of Dove Television to the Europian continent.\r\n         Enjoy non-stop Christian programming from anointed and\r\n         seasoned men of God and more.\r\n          </p></td> \r\n         </tr>\r\n         <tr>\r\n        <td>5</td>\r\n        <td><b>DOVE NORTH-AMERICA</b></td>\r\n        <td><img class=\"iconimage2\" src={ channelimages[0] }/></td>\r\n        <td style={{width:\"40%\"}}><p style={{textAlign:\"justify\"}}>\r\n        Dove North America is an extended arm of Dove Television to the America continent. Enjoy non-stop \r\n        Christian programming from anointed and\r\n        seasoned men of God and more.\r\n        </p></td> \r\n         </tr>\r\n      </tbody>\r\n    </Table>\r\n    <br/>\r\n       <br/>\r\n       </div>\r\n      <Footer/>\r\n    </div>\r\n  );\r\n}\r\nexport default Channels;","C:\\Users\\Dozie Steven Emeka\\Documents\\Projects\\Javascript\\Webapp\\ohprimetv-main\\ohprimetv-main\\src\\Containers\\Getstartedpage\\Getstartedpage.jsx",["102","103","104","105","106","107"],[],"import React from \"react\";\r\nimport Navbar from \"../../Components/Navbar/Navbar\";\r\nimport { getstarted } from \"../../images/image\";\r\nimport Footer from \"../../Components/Footer/Footer\";\r\nimport Backgroundimage from \"../../Components/Backgroundimage/Backgroundimage\";\r\nimport './Getstartedpage.css';\r\n\r\n\r\nfunction Getstarted(){\r\n return(\r\n           <div>\r\n           <Navbar getstarted={{backgroundColor:\"white\",color:\"black\"}}>\r\n          </Navbar>\r\n           <Backgroundimage pagetitle1='Getstarted' pagetitle2='Getstarted'>\r\n          </Backgroundimage>\r\n          <br/>\r\n          <br/>\r\n          <h1 class=\"text-center a-h1\">Getstarted \r\n          <span className=\"span-h1\">now</span></h1> \r\n          <br/>\r\n          <h4 class='text-center'>Get The Mobile App Version Now On \r\n          <span className=\"span-h1\">Apple Store Or Google Play Store</span></h4>\r\n           <div class='text-center center'>\r\n           <div class='row a-row'>\r\n           <div class='col-12'>\r\n            <div class=\"mobileview\">\r\n            <img src={getstarted[0]} style={{width:\"100%\"}}/>\r\n            </div>\r\n            <div class=\"not-mobileview\">\r\n            <img src={getstarted[0]} class='w-50'/>\r\n            </div>\r\n            </div>\r\n            <div class='col-6'>\r\n            <div class=\"mobileview\">\r\n            <img src={getstarted[1]} class='dbutton' style={{width:\"100%\"}}/>\r\n            <a href=\"https://apps.apple.com/ng/app/oh-prime/id1573372232\"><img src={getstarted[2]} class='dbutton' style={{width:\"100%\"}}/></a>\r\n            </div>\r\n            <div class=\"not-mobileview\">\r\n            <div style={{display:\"inline-block\"}}>\r\n            <a href=\"https://apps.apple.com/ng/app/oh-prime/id1573372232\"><img src={getstarted[2]} class='dbutton' style={{width:\"50%\"}}/></a> \r\n\r\n            <a href=\"https://apps.apple.com/ng/app/oh-prime/id1573372232\"><img src={getstarted[1]} style={{width:\"50%\"}}/></a>\r\n            </div>\r\n            </div>\r\n            <br/>\r\n            <br/>\r\n            <br/>\r\n           </div>\r\n           </div>\r\n           </div>\r\n          <Footer/>\r\n          </div>\r\n );\r\n}\r\n\r\nexport default Getstarted","C:\\Users\\Dozie Steven Emeka\\Documents\\Projects\\Javascript\\Webapp\\ohprimetv-main\\ohprimetv-main\\src\\images\\image.js",[],[],"C:\\Users\\Dozie Steven Emeka\\Documents\\Projects\\Javascript\\Webapp\\ohprimetv-main\\ohprimetv-main\\src\\Components\\Backgroundcolor\\Backgroundcolor.jsx",[],[],"C:\\Users\\Dozie Steven Emeka\\Documents\\Projects\\Javascript\\Webapp\\ohprimetv-main\\ohprimetv-main\\src\\Components\\Navbar\\Navbar.jsx",["108"],[],"\r\nimport React from \"react\";\r\nimport 'bootstrap/dist/css/bootstrap.min.css';\r\nimport { Link } from \"react-router-dom\";\r\nimport './Navbar.css'\r\n\r\nfunction Navbar(active){\r\n     return(\r\n     <div>\r\n     <div className=\"webname pb-3\">\r\n     <img src=\"https://res.cloudinary.com/prince-stevzy/image/upload/v1682592838/m507t0006_retro_tv_20june22_03-removebg-preview_1_bya9e6.png\" class=\"ohprime-logo\"/>\r\n     <font id=\"head\">Ohprime Tv</font><br/>\r\n     <nav id=\"link\">\r\n      <Link to=\"/\"      style={active.home}>Home</Link>\r\n      <Link to=\"/about\" style={active.about}>About us</L